<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="refresh" content="90">
  <title>Rangliste · WM 2026 EmiLe</title>
  <link rel="stylesheet" href="/css/style.css">
  <meta name="theme-color" content="#2D6A35">
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,700;0,9..144,900;1,9..144,400&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    .pub-header { background: var(--green); color: #fff; padding: 18px 24px; display: flex; align-items: center; gap: 16px; }
    .pub-header img { height: 36px; filter: brightness(0) invert(1); }
    .pub-header .pub-title { font-family: 'Fraunces', serif; font-size: 1.25rem; font-weight: 700; }
    .pub-header .pub-sep { width: 1px; height: 28px; background: rgba(255,255,255,.35); }
    .pub-refresh { font-size: .72rem; color: rgba(255,255,255,.65); margin-left: auto; }
    .pub-wrap { max-width: 760px; margin: 32px auto; padding: 0 16px 48px; }
    .pub-lead { font-size: .85rem; color: var(--text2); margin-bottom: 20px; }
  </style>
</head>
<body>

<div class="pub-header">
  <img src="https://www.emile-montessori.de/wp-content/uploads/logo-emile-eine-schule-551x143.png" alt="EmiLe">
  <div class="pub-sep"></div>
  <span class="pub-title">⚽ WM 2026 · Tippspiel-Rangliste</span>
  <span class="pub-refresh">Aktualisiert automatisch alle 90 Sek.</span>
</div>

<div class="pub-wrap">
  <p class="pub-lead">Gesamtrangliste aller Tipper &mdash; Spielstand vom <%= new Date().toLocaleString('de-DE', {day:'2-digit', month:'2-digit', hour:'2-digit', minute:'2-digit'}) %> Uhr</p>

  <table class="ranking-table">
    <thead>
      <tr>
        <th>#</th>
        <th>Name</th>
        <th>Punkte</th>
        <th class="points-detail">davon ⚡</th>
      </tr>
      <tr class="rank-tiebreak-hint"><td colspan="4">Bei Punktgleichheit z&auml;hlt zuerst die regul&auml;r getippte Punktzahl; der Powerspiel-Bonus wird nachrangig gewertet.</td></tr>
    </thead>
    <tbody>
      <% overall.forEach((u) => { %>
      <tr class="<%= u.disqualified ? 'row-disq' : '' %>">
        <td class="rank-num">
          <% if (u.disqualified) { %>🚫<% } else if (u.rank === 1) { %>🥇<% } else if (u.rank === 2) { %>🥈<% } else if (u.rank === 3) { %>🥉<% } else { %><%= u.rank %><% } %>
        </td>
        <td class="rank-name"><%= u.display_name %></td>
        <td class="rank-points"><strong><%= u.grand_total %></strong></td>
        <td class="points-detail points-power"><% if (u.power_points > 0) { %>+<%= u.power_points %><% } else { %>&ndash;<% } %></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>

</body>
</html>
