<%- include('partials/header') %>
<div class="auth-page">
  <div class="auth-card">
    <div class="auth-logo">
      <img src="https://www.emile-montessori.de/wp-content/uploads/logo-emile-eine-schule-551x143.png" alt="EmiLe" class="auth-school-logo">
      <div class="auth-wm-badge">⚽ WM 2026 Tippspiel</div>
    </div>
    <h1 class="auth-title">Passwort vergessen</h1>
    <p class="auth-sub">Gib deinen Benutzernamen ein — wir setzen dir ein temporäres Passwort.</p>

    <% if (error) { %>
    <div class="alert alert-error"><%= error %></div>
    <% } %>

    <form method="POST" action="/auth/forgot" class="auth-form">
      <div class="field">
        <label>Benutzername</label>
        <input type="text" name="username" required autocomplete="username" placeholder="z.B. familie-wontke">
      </div>
      <button type="submit" class="btn btn-primary btn-full">Temporäres Passwort anfordern</button>
    </form>
    <p class="auth-switch"><a href="/auth/login">Zurück zum Login</a></p>
  </div>
</div>
<%- include('partials/footer') %>
