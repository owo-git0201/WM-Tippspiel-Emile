<%- include('partials/header') %>

<div class="page-hero">
  <div class="hero-inner">
    <div class="hero-text">
      <h1>&#x26BD; WM 2026 Tippspiel</h1>
      <p class="hero-powered"><em>Powered by AK Sport</em></p>

      <!-- FORTSCHRITTSBALKEN -->
      <div class="tip-progress-wrap">
        <div class="tip-progress-label">
          <span class="tip-progress-count"><%= tippedCount %> / <%= totalGames %></span>
          <span class="tip-progress-text">Spiele getippt</span>
        </div>
        <div class="tip-progress-bar">
          <div class="tip-progress-fill" style="width:<%= totalGames > 0 ? Math.round(tippedCount/totalGames*100) : 0 %>%"></div>
        </div>
        <% if (tippedCount === totalGames && totalGames > 0) { %>
        <div class="tip-progress-done">&#x2713; Alle Spiele getippt!</div>
        <% } %>
      </div>
    </div>

    <div class="hero-right">
      <div class="scoring-legend">
        <div class="legend-item"><span class="badge badge-green">2 Pkt</span> Tendenz</div>
        <div class="legend-item"><span class="badge badge-gold">4 Pkt</span> Exakt</div>
        <div class="legend-item"><span class="badge badge-orange">&#x26A1; &times;3</span> Powerspiel</div>
        <div class="legend-item"><span class="badge badge-red">&times;2&ndash;4</span> KO</div>
        <p class="legend-sub">Tendenz richtig = <strong>2 Pkt</strong> &middot; Exaktes Ergebnis = <strong>4 Pkt</strong> &middot; Powerspiel = <strong>&times;3</strong></p>
      </div>
      <% if (powerplayUsed) { %>
      <div class="hero-powerplay-banner hero-powerplay-set">&#x26A1; Powerspiel diese Woche bereits gesetzt.</div>
      <% } else { %>
      <div class="hero-powerplay-banner">&#x1F4A1; <strong>Powerspiel:</strong> W&auml;hle ein Spiel pro Woche &ndash; Punkte &times;3!</div>
      <% } %>
    </div>
  </div>
</div>

<!-- SPÄTSTARTER-BANNER -->
<% if (typeof lateJoinOpen !== 'undefined' && lateJoinOpen) { %>
<div class="latejoin-banner">
  <span class="latejoin-dice">🎲</span>
  <span><strong>Spätstarter willkommen!</strong> Wer jetzt noch einsteigt, bekommt bereits gespielte Partien automatisch aus den abgegebenen Tipps eines zufälligen Mitspielers zugeteilt — gleiche Chancen für alle. Sagt's weiter: Anmeldung bis Ende der Gruppenphase möglich!</span>
</div>
<% } %>

<!-- COUNTDOWN BANNER -->
<% if (nextGame) { %>
<div class="countdown-bar" data-kickoff="<%= new Date(nextGame.kickoff).toISOString() %>">
  <div class="countdown-inner">
    <div class="countdown-game">
      <span class="countdown-flag"><%= nextGame.home_flag %></span>
      <span class="countdown-teams"><%= nextGame.home_team %> vs <%= nextGame.away_team %></span>
      <span class="countdown-flag"><%= nextGame.away_flag %></span>
    </div>
    <div class="countdown-timer">
      <div class="countdown-unit"><span class="countdown-num" id="cd-d">--</span><span class="countdown-label">T</span></div>
      <div class="countdown-sep">:</div>
      <div class="countdown-unit"><span class="countdown-num" id="cd-h">--</span><span class="countdown-label">Std</span></div>
      <div class="countdown-sep">:</div>
      <div class="countdown-unit"><span class="countdown-num" id="cd-m">--</span><span class="countdown-label">Min</span></div>
      <div class="countdown-sep">:</div>
      <div class="countdown-unit"><span class="countdown-num" id="cd-s">--</span><span class="countdown-label">Sek</span></div>
    </div>
  </div>
</div>
<% } %>

<div class="page-content">

  <!-- WM-SIEGER TIPP -->
  <% if (championOpen || championTip) { %>
  <div class="champion-box">
    <div class="champion-header">
      <span class="champion-icon">&#x1F3C6;</span>
      <div>
        <div class="champion-title">WM-Sieger tippen &mdash; <span class="badge badge-gold">20 Punkte</span></div>
        <div class="champion-sub">
          <% if (championOpen) { %>
          Einmalig tippbar bis <strong>19. Juni 2026</strong> (nach dem ersten Spieltag aller Teams).
          <% } else { %>
          Tipp-Deadline abgelaufen.
          <% } %>
        </div>
      </div>
    </div>
    <% if (championTip) { %>
    <div class="champion-current">
      Dein Tipp: <strong><%= championTip.team %></strong>
      <% if (championTip.points !== null) { %>
        <span class="points-earned <%= championTip.points > 0 ? 'points-green' : 'points-zero' %>">
          <%= championTip.points > 0 ? '+20 Punkte!' : 'Leider nicht' %>
        </span>
      <% } %>
      <% if (championOpen) { %><span class="champion-change">(kannst du noch &auml;ndern)</span><% } %>
    </div>
    <% } %>
    <% if (championOpen) { %>
    <form method="POST" action="/champion" class="champion-form">
      <select name="team" required class="champion-select">
        <option value="">&mdash; Team ausw&auml;hlen &mdash;</option>
        <% allTeams.forEach(t => { %>
        <option value="<%= t %>" <%= championTip && championTip.team === t ? 'selected' : '' %>><%= t %></option>
        <% }) %>
      </select>
      <button type="submit" class="btn btn-primary">&#x1F3C6; Tippen</button>
    </form>
    <% } %>
  </div>
  <% } %>

  <!-- VIEW TABS -->
  <div class="view-tabs">
    <button class="tab-btn active" data-view="day">&#x1F4C5; Nach Tag</button>
    <button class="tab-btn" data-view="matchday">&#x26BD; Spieltag</button>
    <button class="tab-btn" data-view="group">&#x1F5C2; Nach Gruppe</button>
  </div>

  <!-- NACH TAG -->
  <div class="view-panel active" id="view-day">
    <% Object.keys(byDay).forEach(dayKey => { %>
    <div class="game-group">
      <h2 class="group-title"><%= dayKey %></h2>
      <div class="games-grid">
        <% byDay[dayKey].forEach(game => { %>
        <%- include('partials/game-card', { game, powerplayUsed }) %>
        <% }) %>
      </div>
    </div>
    <% }) %>
  </div>

  <!-- NACH SPIELTAG -->
  <div class="view-panel" id="view-matchday">
    <% Object.keys(byMatchday).forEach(mdKey => { %>
    <div class="game-group">
      <h2 class="group-title"><%= mdKey %></h2>
      <div class="games-grid">
        <% byMatchday[mdKey].forEach(game => { %>
        <%- include('partials/game-card', { game, powerplayUsed }) %>
        <% }) %>
      </div>
    </div>
    <% }) %>
  </div>

  <!-- NACH GRUPPE -->
  <div class="view-panel" id="view-group">
    <% Object.keys(byGroup).forEach(groupKey => { %>
    <div class="game-group">
      <h2 class="group-title"><%= groupKey %></h2>
      <div class="games-grid">
        <% byGroup[groupKey].forEach(game => { %>
        <%- include('partials/game-card', { game, powerplayUsed }) %>
        <% }) %>
      </div>
    </div>
    <% }) %>
  </div>

</div>
<%- include('partials/footer') %>
