<%- include('partials/header') %>

<div class="page-hero">
  <div class="hero-inner">
    <div class="hero-text">
      <h1>&#x26BD; WM 2026 Tippspiel</h1>
      <p class="hero-powered"><em>Powered by AK Sport</em></p>
    </div>
    <div class="hero-right">
      <div class="scoring-legend">
        <div class="legend-item"><span class="badge badge-green">2 Pkt</span> Tendenz</div>
        <div class="legend-item"><span class="badge badge-gold">4 Pkt</span> Exakt</div>
        <div class="legend-item"><span class="badge badge-orange">&#x26A1; &times;3</span> Powerspiel</div>
        <div class="legend-item"><span class="badge badge-red">&times;2&ndash;4</span> KO</div>
        <p class="legend-sub">Tendenz richtig = <strong>2 Pkt</strong> &middot; Exaktes Ergebnis = <strong>4 Pkt</strong> &middot; Powerspiel = <strong>&times;3</strong></p>
      </div>
      <% if (powerplayUsed) { %>
      <div class="hero-powerplay-banner hero-powerplay-set">&#x26A1; Powerspiel diese Woche bereits gesetzt.</div>
      <% } else { %>
      <div class="hero-powerplay-banner">&#x1F4A1; <strong>Powerspiel:</strong> W&auml;hle ein Spiel pro Woche &ndash; Punkte &times;3! Mutige werden belohnt.</div>
      <% } %>
    </div>
  </div>
</div>

<div class="page-content">

  <!-- WM-SIEGER TIPP -->
  <% if (championOpen || championTip) { %>
  <div class="champion-box">
    <div class="champion-header">
      <span class="champion-icon">&#x1F3C6;</span>
      <div>
        <div class="champion-title">WM-Sieger tippen &mdash; <span class="badge badge-gold">20 Punkte</span></div>
        <div class="champion-sub">
          <% if (championOpen) { %>
          Einmalig tippbar bis <strong>19. Juni 2026</strong> (nach dem ersten Spieltag aller Teams).
          <% } else { %>
          Tipp-Deadline abgelaufen.
          <% } %>
        </div>
      </div>
    </div>
    <% if (championTip) { %>
    <div class="champion-current">
      Dein Tipp: <strong><%= championTip.team %></strong>
      <% if (championTip.points !== null) { %>
        <span class="points-earned <%= championTip.points > 0 ? 'points-green' : 'points-zero' %>">
          <%= championTip.points > 0 ? '+20 Punkte!' : 'Leider nicht' %>
        </span>
      <% } %>
      <% if (championOpen) { %><span class="champion-change">(kannst du noch &auml;ndern)</span><% } %>
    </div>
    <% } %>
    <% if (championOpen) { %>
    <form method="POST" action="/champion" class="champion-form">
      <select name="team" required class="champion-select">
        <option value="">&mdash; Team ausw&auml;hlen &mdash;</option>
        <% allTeams.forEach(t => { %>
        <option value="<%= t %>" <%= championTip && championTip.team === t ? 'selected' : '' %>><%= t %></option>
        <% }) %>
      </select>
      <button type="submit" class="btn btn-primary">&#x1F3C6; Tippen</button>
    </form>
    <% } %>
  </div>
  <% } %>

  <!-- VIEW TABS -->
  <div class="view-tabs">
    <button class="tab-btn active" data-view="day">&#x1F4C5; Nach Tag</button>
    <button class="tab-btn" data-view="group">&#x1F5C2;&#xFE0F; Nach Gruppe</button>
  </div>

  <!-- NACH TAG -->
  <div class="view-panel active" id="view-day">
    <% Object.keys(byDay).forEach(dayKey => { %>
    <div class="game-group">
      <h2 class="group-title"><%= dayKey %></h2>
      <div class="games-grid">
        <% byDay[dayKey].forEach(game => { %>
        <%- include('partials/game-card', { game, powerplayUsed }) %>
        <% }) %>
      </div>
    </div>
    <% }) %>
  </div>

  <!-- NACH GRUPPE -->
  <div class="view-panel" id="view-group">
    <% Object.keys(byGroup).forEach(groupKey => { %>
    <div class="game-group">
      <h2 class="group-title"><%= groupKey %></h2>
      <div class="games-grid">
        <% byGroup[groupKey].forEach(game => { %>
        <%- include('partials/game-card', { game, powerplayUsed }) %>
        <% }) %>
      </div>
    </div>
    <% }) %>
  </div>

</div>
<%- include('partials/footer') %>
