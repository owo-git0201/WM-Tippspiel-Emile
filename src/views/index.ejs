<%- include('partials/header') %>

<div class="page-hero">
  <div class="hero-inner">
    <div class="hero-text">
      <h1>&#x26BD; WM 2026 Tippspiel</h1>
      <p class="hero-powered"><em>Powered by AK Sport</em></p>

      <!-- FORTSCHRITTSBALKEN -->
      <div class="tip-progress-wrap">
        <div class="tip-progress-label">
          <span class="tip-progress-count"><%= tippedCount %> / <%= totalGames %></span>
          <span class="tip-progress-text">Spiele getippt</span>
        </div>
        <div class="tip-progress-bar">
          <div class="tip-progress-fill" style="width:<%= totalGames > 0 ? Math.round(tippedCount/totalGames*100) : 0 %>%"></div>
        </div>
        <% if (tippedCount === totalGames && totalGames > 0) { %>
        <div class="tip-progress-done">&#x2713; Alle Spiele getippt!</div>
        <% } %>
      </div>
    </div>

    <div class="hero-right">
      <div class="scoring-legend">
        <div class="legend-item"><span class="badge badge-green">2 Pkt</span> Tendenz</div>
        <div class="legend-item"><span class="badge badge-gold">4 Pkt</span> Exakt</div>
        <div class="legend-item"><span class="badge badge-orange">&#x26A1; &times;3</span> Powerspiel</div>
        <div class="legend-item"><span class="badge badge-red">&times;2&ndash;4</span> K.O.</div>
        <p class="legend-sub">K.O.: <strong>&times;2</strong> R32/R16 &middot; <strong>&times;3</strong> VF/HF &middot; <strong>&times;4</strong> Finale</p>
        <p class="legend-sub">Powerspiel <strong>&times;3</strong> &mdash; Fehltipp = <span style="color:var(--red)">Minus</span> &middot; Tipp gilt f&uuml;r 90 Min.</p>
      </div>
      <div class="hero-powerplay-banner">&#x26A1; <strong>K.O.-Phase:</strong> 1 Powerspiel pro Slot &ndash; ×2 bis ×4 &amp; Risiko!</div>
    </div>
  </div>
</div>

<!-- COUNTDOWN BANNER -->
<% if (nextGame) { %>
<div class="countdown-bar" data-kickoff="<%= new Date(nextGame.kickoff).toISOString() %>">
  <div class="countdown-inner">
    <div class="countdown-game">
      <span class="countdown-flag"><%= nextGame.home_flag %></span>
      <span class="countdown-teams"><%= nextGame.home_team %> vs <%= nextGame.away_team %></span>
      <span class="countdown-flag"><%= nextGame.away_flag %></span>
    </div>
    <div class="countdown-timer">
      <div class="countdown-unit"><span class="countdown-num" id="cd-d">--</span><span class="countdown-label">T</span></div>
      <div class="countdown-sep">:</div>
      <div class="countdown-unit"><span class="countdown-num" id="cd-h">--</span><span class="countdown-label">Std</span></div>
      <div class="countdown-sep">:</div>
      <div class="countdown-unit"><span class="countdown-num" id="cd-m">--</span><span class="countdown-label">Min</span></div>
      <div class="countdown-sep">:</div>
      <div class="countdown-unit"><span class="countdown-num" id="cd-s">--</span><span class="countdown-label">Sek</span></div>
    </div>
  </div>
</div>
<% } %>

<div class="page-content">

  <!-- WM-SIEGER TIPP -->
  <% if (championOpen || championTip) { %>
  <div class="champion-box">
    <div class="champion-header">
      <span class="champion-icon">&#x1F3C6;</span>
      <div>
        <div class="champion-title">WM-Sieger tippen &mdash; <span class="badge badge-gold">20 Punkte</span></div>
        <div class="champion-sub">
          <% if (championOpen) { %>
          Einmalig tippbar bis <strong>19. Juni 2026</strong> (nach dem ersten Spieltag aller Teams).
          <% } else { %>
          Tipp-Deadline abgelaufen.
          <% } %>
        </div>
      </div>
    </div>
    <% if (championTip) { %>
    <div class="champion-current">
      Dein Tipp: <strong><%= championTip.team %></strong>
      <% if (championTip.points !== null) { %>
        <span class="points-earned <%= championTip.points > 0 ? 'points-green' : 'points-zero' %>">
          <%= championTip.points > 0 ? '+20 Punkte!' : 'Leider nicht' %>
        </span>
      <% } %>
      <% if (championOpen) { %><span class="champion-change">(kannst du noch &auml;ndern)</span><% } %>
    </div>
    <% } %>
    <% if (championOpen) { %>
    <form method="POST" action="/champion" class="champion-form">
      <select name="team" required class="champion-select">
        <option value="">&mdash; Team ausw&auml;hlen &mdash;</option>
        <% allTeams.forEach(t => { %>
        <option value="<%= t %>" <%= championTip && championTip.team === t ? 'selected' : '' %>><%= t %></option>
        <% }) %>
      </select>
      <button type="submit" class="btn btn-primary">&#x1F3C6; Tippen</button>
    </form>
    <% } %>
  </div>
  <% } %>

  <!-- K.O.-PHASE REGELN-BANNER -->
  <% const hasKOGames = games.some(g => g.round !== 'Gruppenphase'); %>
  <% if (hasKOGames) { %>
  <div class="ko-rules-banner">
    <div class="ko-rules-header">⚡ K.O.-Phase läuft</div>
    <div class="ko-rules-grid">
      <div class="ko-rules-item">
        <div class="ko-rules-item-title">📈 Mehr Punkte</div>
        <div class="ko-rules-item-body">&times;2 Runde der 32 &amp; 16<br>&times;3 Viertelfinale &amp; Halbfinale<br>&times;4 Finale</div>
      </div>
      <div class="ko-rules-sep"></div>
      <div class="ko-rules-item">
        <div class="ko-rules-item-title">⚡ Powerspiel &times;3 — mit Risiko</div>
        <div class="ko-rules-item-body">Richtiger Tipp: Punkte &times;3<br><span class="ko-minus-hint">Falscher Tipp: Minuspunkte!</span><br><em>Gut &uuml;berlegen lohnt sich.</em></div>
      </div>
      <div class="ko-rules-sep"></div>
      <div class="ko-rules-item">
        <div class="ko-rules-item-title">🎯 3 Powerspiel-Slots</div>
        <div class="ko-rules-item-body">1&times; Runde der 32<br>1&times; Runde der 16<br>1&times; VF + HF + Finale</div>
      </div>
    </div>
    <div class="ko-rules-footer">⏱ Tipp gilt f&uuml;r das Ergebnis nach <strong>90 Minuten</strong> &mdash; auch Unentschieden ist m&ouml;glich. Verl&auml;ngerung &amp; Elfmeter z&auml;hlen nicht.</div>
  </div>

  <!-- K.O.-PHASE WILLKOMMEN (einmalig, 3 Tage) -->
  <div class="ko-welcome-card" id="ko-welcome" style="display:none">
    <button class="ko-welcome-close" onclick="dismissKOWelcome()" aria-label="schließen">&times;</button>
    <div class="ko-welcome-title">🆕 Was hat sich zur K.O.-Phase geändert?</div>
    <div class="ko-welcome-body">
      <div class="ko-welcome-row">
        <span class="ko-welcome-icon">📈</span>
        <div><strong>Multiplikatoren:</strong> Alle K.O.-Tipps bringen mehr Punkte — je weiter die Runde, desto h&ouml;her der Faktor (×2 bis ×4). Ein richtiger Tipp im Finale z&auml;hlt viermal so viel wie in der Gruppenphase.</div>
      </div>
      <div class="ko-welcome-row">
        <span class="ko-welcome-icon">⚡</span>
        <div><strong>Powerspiel mit Risiko:</strong> Das Powerspiel verdreifacht deinen Tipp wie gewohnt — aber NEU: Liegst du mit einem K.O.-Powerspiel falsch, kostet es dich <strong>&minus;8 Pkt</strong> (R32/R16), <strong>&minus;12 Pkt</strong> (VF/HF) oder <strong>&minus;16 Pkt</strong> (Finale). Gut &uuml;berlegen lohnt sich &mdash; ein Fehlschuss kann die Rangliste durchsch&uuml;tteln.</div>
      </div>
      <div class="ko-welcome-row">
        <span class="ko-welcome-icon">🎯</span>
        <div><strong>3 Powerspiele für die ganze K.O.-Phase:</strong> Je 1 Powerspiel f&uuml;r Runde der 32, Runde der 16 und den Block VF+HF+Finale. Gut planen!</div>
      </div>
    </div>
    <button class="btn btn-primary btn-sm ko-welcome-btn" onclick="dismissKOWelcome()">Alles klar — los tippen! ⚡</button>
  </div>
  <script>
    (function() {
      var seen = localStorage.getItem('ko_phase_seen_v1');
      var deadline = new Date('2026-07-01T23:59:00');
      if (!seen && new Date() <= deadline) {
        document.getElementById('ko-welcome').style.display = '';
      }
    })();
    function dismissKOWelcome() {
      localStorage.setItem('ko_phase_seen_v1', '1');
      document.getElementById('ko-welcome').style.display = 'none';
    }
  </script>
  <% } %>

  <!-- VIEW TABS -->
  <div class="view-tabs">
    <button class="tab-btn active" data-view="day">&#x26A1; K.O.-Phase</button>
    <button class="tab-btn" data-view="groupstage">&#x1F4CB; Gruppenphase</button>
    <button class="tab-btn" data-view="matchday">&#x26BD; Spieltag</button>
    <button class="tab-btn" data-view="group">&#x1F5C2; Gruppe</button>
  </div>

  <!-- K.O.-PHASE NACH TAG -->
  <div class="view-panel active" id="view-day">
    <%
      const now = new Date();
      const r16DayMap = {};
      const r32DayMap = {};
      Object.keys(byDay).forEach(function(dayKey) {
        const r16 = byDay[dayKey].filter(function(g) { return g.round !== 'Gruppenphase' && g.round !== 'Runde der 32'; });
        const r32 = byDay[dayKey].filter(function(g) { return g.round === 'Runde der 32'; });
        if (r16.length > 0) r16DayMap[dayKey] = r16;
        if (r32.length > 0) r32DayMap[dayKey] = r32;
      });
      const hasR16 = Object.keys(r16DayMap).length > 0;
      const hasR32 = Object.keys(r32DayMap).length > 0;
      const r32HasFuture = Object.values(r32DayMap).reduce(function(a,b){return a.concat(b);}, []).some(function(g){ return new Date(g.kickoff) > now; });
      const r16HasFuture = Object.values(r16DayMap).reduce(function(a,b){return a.concat(b);}, []).some(function(g){ return new Date(g.kickoff) > now; });
    %>
    <% if (!hasR16 && !hasR32) { %>
    <div class="empty-hint">K.O.-Spiele erscheinen hier sobald sie beginnen.</div>
    <% } %>

    <!-- Runde der 32 — einklappbar, offen wenn noch Spiele offen -->
    <% if (hasR32) { %>
    <div class="ko-collapse <%= r32HasFuture ? 'open' : '' %>" id="r32-section">
      <button class="ko-collapse-btn" data-section="r32-section" data-open="▲ Runde der 32 verbergen" data-closed="▼ Runde der 32 anzeigen" onclick="toggleKO(this)">
        <%= r32HasFuture ? '▲ Runde der 32 verbergen' : '▼ Runde der 32 anzeigen' %>
      </button>
      <div class="ko-collapse-body">
        <% Object.keys(r32DayMap).forEach(function(dayKey) { %>
        <div class="game-group">
          <h2 class="group-title"><%= dayKey %></h2>
          <div class="games-grid">
            <% r32DayMap[dayKey].forEach(function(game) { %>
            <%- include('partials/game-card', { game, powerplaysByMatchday }) %>
            <% }) %>
          </div>
        </div>
        <% }) %>
      </div>
    </div>
    <% } %>

    <!-- Achtelfinale (Runde der 16) — einklappbar, offen wenn noch Spiele offen -->
    <% if (hasR16) { %>
    <div class="ko-collapse <%= r16HasFuture ? 'open' : '' %>" id="r16-section">
      <button class="ko-collapse-btn" data-section="r16-section" data-open="▲ Achtelfinale verbergen" data-closed="▼ Achtelfinale anzeigen" onclick="toggleKO(this)">
        <%= r16HasFuture ? '▲ Achtelfinale verbergen' : '▼ Achtelfinale anzeigen' %>
      </button>
      <div class="ko-collapse-body">
        <% Object.keys(r16DayMap).forEach(function(dayKey) { %>
        <div class="game-group">
          <h2 class="group-title"><%= dayKey %></h2>
          <div class="games-grid">
            <% r16DayMap[dayKey].forEach(function(game) { %>
            <%- include('partials/game-card', { game, powerplaysByMatchday }) %>
            <% }) %>
          </div>
        </div>
        <% }) %>
      </div>
    </div>
    <% } %>

    <script>
      function toggleKO(btn) {
        var el = document.getElementById(btn.dataset.section);
        el.classList.toggle('open');
        btn.textContent = el.classList.contains('open') ? btn.dataset.open : btn.dataset.closed;
      }
    </script>
  </div>

  <!-- GRUPPENPHASE -->
  <div class="view-panel" id="view-groupstage">
    <% ['1. Spieltag', '2. Spieltag', '3. Spieltag'].forEach(mdKey => { %>
    <% if (byMatchday[mdKey]) { %>
    <div class="game-group">
      <h2 class="group-title"><%= mdKey %></h2>
      <div class="games-grid">
        <% byMatchday[mdKey].forEach(game => { %>
        <%- include('partials/game-card', { game, powerplaysByMatchday }) %>
        <% }) %>
      </div>
    </div>
    <% } %>
    <% }) %>
  </div>

  <!-- NACH SPIELTAG -->
  <div class="view-panel" id="view-matchday">
    <% Object.keys(byMatchday).forEach(mdKey => { %>
    <div class="game-group">
      <h2 class="group-title"><%= mdKey %></h2>
      <div class="games-grid">
        <% byMatchday[mdKey].forEach(game => { %>
        <%- include('partials/game-card', { game, powerplaysByMatchday }) %>
        <% }) %>
      </div>
    </div>
    <% }) %>
  </div>

  <!-- NACH GRUPPE -->
  <div class="view-panel" id="view-group">
    <% Object.keys(byGroup).forEach(groupKey => { %>
    <div class="game-group">
      <h2 class="group-title"><%= groupKey %></h2>
      <div class="games-grid">
        <% byGroup[groupKey].forEach(game => { %>
        <%- include('partials/game-card', { game, powerplaysByMatchday }) %>
        <% }) %>
      </div>
    </div>
    <% }) %>
  </div>

</div>
<%- include('partials/footer') %>
